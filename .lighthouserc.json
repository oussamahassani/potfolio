{
  "extends": "lighthouse:default",
  "settings": {
    "numWorkers": 1,
    "locale": "en-US",
    "output": ["html", "json"],
    "onlyCategories": [
      "performance",
      "accessibility",
      "best-practices",
      "seo",
      "pwa"
    ],
    "skipAudits": [],
    "skipAboutBlank": false,
    "extraHeaders": null,
    "maxWaitForFcp": 30000,
    "maxWaitForLoad": 45000,
    "maxResponseWaitTime": 10000,
    "pageLoadStrategy": "compute",
    "formFactor": "mobile",
    "throttling": {
      "rttMs": 150,
      "throughputKbps": 1638.4,
      "cpuSlowdownMultiplier": 4,
      "downloadThroughputKbps": 1638.4,
      "uploadThroughputKbps": 409.6,
      "requestLatencyMs": 150
    },
    "screenEmulation": {
      "mobile": true,
      "width": 412,
      "height": 823,
      "deviceScaleFactor": 1.75,
      "disabled": false
    },
    "emulatedUserAgent": "Mozilla/5.0 (Linux; Android 11; Samsung Galaxy A12) AppleWebKit/537.36",
    "channel": "chrome",
    "budgets": [
      {
        "resourceSizes": [
          {
            "resourceType": "script",
            "budget": 170
          },
          {
            "resourceType": "stylesheet",
            "budget": 50
          },
          {
            "resourceType": "image",
            "budget": 200
          },
          {
            "resourceType": "font",
            "budget": 100
          }
        ],
        "resourceCounts": [
          {
            "resourceType": "total",
            "budget": 50
          },
          {
            "resourceType": "script",
            "budget": 15
          },
          {
            "resourceType": "stylesheet",
            "budget": 5
          }
        ],
        "timings": [
          {
            "metric": "first-contentful-paint",
            "budget": 2500
          },
          {
            "metric": "largest-contentful-paint",
            "budget": 2500
          },
          {
            "metric": "first-input-delay",
            "budget": 100
          },
          {
            "metric": "cumulative-layout-shift",
            "budget": 0.1
          },
          {
            "metric": "total-blocking-time",
            "budget": 150
          }
        ]
      }
    ]
  },
  "audits": {},
  "categories": {
    "performance": {
      "title": "Performance",
      "auditRefs": [
        { "id": "first-contentful-paint", "weight": 10, "group": "metrics" },
        { "id": "largest-contentful-paint", "weight": 25, "group": "metrics" },
        { "id": "first-input-delay", "weight": 30, "group": "metrics" },
        { "id": "cumulative-layout-shift", "weight": 25, "group": "metrics" },
        { "id": "total-blocking-time", "weight": 10, "group": "metrics" }
      ]
    },
    "accessibility": {
      "title": "Accessibility",
      "auditRefs": [
        { "id": "aria-hidden-body", "weight": 0, "group": "aria" },
        { "id": "document-title", "weight": 3, "group": "labels-and-names" }
      ]
    },
    "best-practices": {
      "title": "Best Practices",
      "auditRefs": [
        { "id": "errors-in-console", "weight": 1 },
        { "id": "deprecations-in-console", "weight": 1 }
      ]
    },
    "seo": {
      "title": "SEO",
      "auditRefs": [
        { "id": "viewport", "weight": 10 },
        { "id": "document-title", "weight": 10 },
        { "id": "meta-description", "weight": 10 }
      ]
    },
    "pwa": {
      "title": "PWA",
      "auditRefs": [
        { "id": "service-worker", "weight": 0 },
        { "id": "manifest-exists", "weight": 0 }
      ]
    }
  }
}
